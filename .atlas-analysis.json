  "keyFeatures": [
    "DAO pattern with JDBC for MySQL — clean separation of persistence logic",
    "CSV export of crew members without assigned missions",
    "XML (operaciones_esa.xml) batch processing: updates missions and inserts/updates crew",
    "Console menu for selecting operations at runtime",
    "Centralised JDBC connection management via GestorConexionJDBC",
    "External properties-based configuration (aplicacion.properties)",
    "Custom exception hierarchy (AgenciaEsaException) with typed error codes"
  ],
  "publicApiSurface": [
